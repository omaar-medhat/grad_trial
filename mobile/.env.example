# =============================================================================
# PulseGuard AI Mobile App - Environment (mobile/.env.example)
# -----------------------------------------------------------------------------
# Copy to mobile/.env. EXPO_PUBLIC_ vars are inlined into the JS bundle, so
# they are NOT secret — only put PUBLIC values here.
#
# SECURITY (important):
#   * NEVER put serviceAccountKey.json, Firebase Admin credentials, private
#     keys, or any backend secret in the mobile app or this file.
#   * The mobile app reads ALL telemetry/alerts/reports/profile/goals from the
#     Flask BACKEND APIs. It does NOT read the Firebase Realtime Database
#     directly and does NOT contain the Firebase Admin SDK.
#   * Firebase here is used ONLY for client Authentication (login → uid). The
#     Firebase WEB config below is public and safe to ship.
# =============================================================================

# Backend Flask API base URL — the single source of data for the app.
#   Android emulator: http://10.0.2.2:5000
#   iOS simulator:    http://localhost:5000
#   Physical device:  http://YOUR_LAPTOP_LAN_IP:5000   (e.g. http://192.168.1.20:5000)
EXPO_PUBLIC_API_BASE_URL=http://YOUR_LAPTOP_IP:5000

# Firebase AUTHENTICATION (public web client config). Used only to sign in and
# obtain the user's uid; NOT used to read the database. databaseURL is optional
# and unused by the app (kept for parity with the web config).
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:000000000000000000
# Optional / unused for data reads:
EXPO_PUBLIC_FIREBASE_DATABASE_URL=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Demo mode (true → allow 'Continue as demo' without Firebase Auth).
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_DEMO_USER_ID=demo-user-001
