# =============================================================================
# PulseGuard AI - Environment Variables (.env.example)
# -----------------------------------------------------------------------------
# Copy this file to `.env`:
#   cp .env.example .env
#
# The values below are the actual Firebase config for the lab10prototyping
# project. Firebase web config keys are PUBLIC (safe to share). Security is
# enforced by Firebase Auth + Realtime Database rules.
# =============================================================================

# --- Backend API base URL ---
# In dev, Vite proxies /api → http://127.0.0.1:5000 (see vite.config.ts).
VITE_API_BASE_URL=/api

# --- Firebase Web SDK config (frontend) ---
VITE_FIREBASE_API_KEY=AIzaSyCzUaw-Wsbae4hduwpTQLRXEfw3js6p2Oc
VITE_FIREBASE_AUTH_DOMAIN=lab10prototyping.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://lab10prototyping-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=lab10prototyping
VITE_FIREBASE_STORAGE_BUCKET=lab10prototyping.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=881278505454
VITE_FIREBASE_APP_ID=1:881278505454:web:2feabd7ea553a00301beff
VITE_FIREBASE_MEASUREMENT_ID=G-TX5L44W7D0

# --- Firebase Realtime Database (backend) ---
FIREBASE_DATABASE_URL=https://lab10prototyping-default-rtdb.firebaseio.com

# --- Demo mode ---
VITE_DEMO_MODE=false
VITE_DEMO_USER_ID=demo-user-001
