# =============================================================================
# PulseGuard AI - Frontend Environment Variables (.env.example)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git. See .gitignore.
#
# This project uses Firebase Authentication + Firebase Realtime Database ONLY.
# Cloud Firestore is NOT used.
# Cloud Storage is NOT used.
# Supabase is NOT used.
# =============================================================================

# --- Backend API base URL ---
# In dev, Vite proxies /api → http://127.0.0.1:5000 (see vite.config.ts).
# In prod, set this to your deployed backend.
VITE_API_BASE_URL=/api

# --- Firebase Web SDK config ---
# These values are SAFE to ship in the bundle (Firebase web config is public
# client config). Database access is gated by Firebase Auth + Realtime
# Database security rules (see firebase.rules.json).
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com   # present in config but Cloud Storage is NOT used
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Demo mode ---
# When true, the dashboard always uses the local in-browser simulator and
# skips Firebase reads. Useful for offline demos, CI, screenshots.
VITE_DEMO_MODE=false

# --- Default demo user id (used when Firebase Auth is unavailable) ---
VITE_DEMO_USER_ID=demo-user-001

# --- Active Firebase user id (user-scoped data: /users/{uid}/...) ---
# When set, the app reads this user's live telemetry/history/goals via the
# backend. If empty, the signed-in user's uid is used, else the backend
# resolves it (FIREBASE_ACTIVE_UID or the first /users child with data).
VITE_FIREBASE_ACTIVE_UID=
