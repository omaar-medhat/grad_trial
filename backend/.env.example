# =============================================================================
# PulseGuard AI - Backend Environment Variables (backend/.env.example)
# -----------------------------------------------------------------------------
# Copy this file to `backend/.env` and fill in real values.
# NEVER commit `backend/.env`.
# =============================================================================

# --- Flask ---
FLASK_ENV=development                # development | production
FLASK_DEBUG=1
PORT=5000
HOST=0.0.0.0
LOG_LEVEL=INFO

# --- CORS allowed origins (comma-separated) ---
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:19006

# =============================================================================
# CHAT BRAIN — pick ONE of these to get a real open-domain LLM in the chat.
# If none is set, the chatbot uses the symbolic + trained-NN-classifier path
# (still smart for common health questions, but limited to known intents).
# =============================================================================

# Option A — Groq (recommended: free tier, very fast Llama-3.3-70B)
#   Sign up at https://console.groq.com → API Keys → Create API Key
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Option B — OpenAI (paid, e.g. GPT-4o-mini)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Option C — Anthropic Claude (paid)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Option D — Local Ollama (free, runs on your machine: https://ollama.com)
#   Install Ollama, run `ollama pull llama3.2`, then:
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# Hard wall-clock cap on LLM calls (seconds). After this we fall back.
LLM_TIMEOUT_SECONDS=20

# =============================================================================
# Fine-tuned TinyLlama medical LoRA (optional; slow on CPU). Off by default.
#   LOAD_CHATBOT_MODEL=1 makes /api/chat generate with the fine-tuned model.
#   The adapter defaults to backend/models/medical_slm_adapter when present,
#   so you only need to flip LOAD_CHATBOT_MODEL. On a GPU it loads 4-bit (NF4);
#   on CPU it loads float32 (~10s startup, ~15-20s/reply).
# =============================================================================
LOAD_CHATBOT_MODEL=0
TINY_LLAMA_ADAPTER_PATH=
TINY_LLAMA_BASE_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
CHATBOT_TIMEOUT_SECONDS=20
CHATBOT_MAX_NEW_TOKENS=160

# =============================================================================
# DATA SOURCE — where the live vitals come from (single source of truth).
#   firebase   read ONLY from Firebase /latest_telemetry (+ /history fallback);
#              if stale/missing, show stale/offline — never the simulator.
#   simulator  use the in-process simulator only (explicit demo / testing).
#   auto       prefer Firebase, else simulator (clearly labelled).
# Default for the real project is `firebase`.
# =============================================================================
DATA_SOURCE=firebase

# Device connection / data-freshness thresholds (seconds).
DEVICE_CONNECTED_MAX_SEC=15
DEVICE_STALE_MAX_SEC=60
# A sensor timestamp more than this many seconds in the FUTURE is treated as a
# wrong device clock and ignored (freshness then uses observed payload change).
SENSOR_TS_FUTURE_SKEW_SEC=120

# Numeric label → string maps for the bracelet's risk_level / stress_label.
# The raw integer is always kept too (raw_risk_level / raw_stress_label).
DATA_RISK_MAP=0:low,1:moderate,2:high
DATA_STRESS_MAP=0:no_stress,1:normal,2:high

# =============================================================================
# Firebase (read live user-scoped sensor data: /users/{uid}/...).
#
#   RECOMMENDED — Admin SDK (works even when database rules are LOCKED):
#     set FIREBASE_CREDENTIALS_PATH to a service-account JSON downloaded from
#     Firebase console → Project settings → Service accounts → Generate new
#     private key. The backend reads server-side and BYPASSES database rules,
#     so you do NOT need to relax the rules. The JSON is a SECRET — keep it
#     local, never commit it (see .gitignore).
#
#   FALLBACK — anonymous REST (debug only): with only FIREBASE_DATABASE_URL and
#     no credentials, the backend reads over HTTPS. This works only if the
#     rules allow anonymous read; otherwise reads return 401 and the app
#     reports firebase_read_ok=false with a clear error.
#
#   With neither → in-memory fallback (offline demo / CI).
# =============================================================================
# Absolute (or repo-relative) path to the service-account JSON. PLACEHOLDER —
# put a real local path here; never commit the file itself.
FIREBASE_CREDENTIALS_PATH=backend/serviceAccountKey.json
FIREBASE_DATABASE_URL=https://lab10prototyping-default-rtdb.firebaseio.com
# Optional REST auth token (RTDB DB secret), only used in REST fallback mode
# when rules deny anonymous reads and no service account is configured.
FIREBASE_DB_SECRET=

# Authentication mode.
#   REQUIRE_AUTH=1 → PRODUCTION: every user-scoped request MUST carry a valid
#     Firebase ID token (Authorization: Bearer <token>); the backend verifies it
#     with the Admin SDK and uses the token's uid. No token → 401. ?uid is
#     ignored. (Token verification needs Admin SDK mode.)
#   REQUIRE_AUTH=0 (default) → DEMO/DEV: a valid Bearer token is still honoured
#     if present, but with no token the backend falls back to ?uid then
#     FIREBASE_ACTIVE_UID. Use only for local dev/demo.
REQUIRE_AUTH=0

# Active Firebase user id for the user-scoped paths (/users/{uid}/...).
# MUST point to the user whose bracelet is CURRENTLY streaming, so the
# dashboard/chatbot show live "connected" data. Used when no ?uid query is
# supplied; if empty, the backend falls back to the first /users child that
# has latest_telemetry. Do NOT hardcode a real uid in code (env only).
FIREBASE_ACTIVE_UID=your-streaming-bracelet-user-id

# Default demo uid (used by legacy per-user endpoints when no auth is present).
DEFAULT_DEMO_UID=demo-user-001
