# Environment files — NEVER commit real secrets
.env
.env.local
.env.development
.env.production
.env.*.local
mobile/.env
backend/.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
